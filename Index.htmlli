  <!-- ══════════════════════════════════════
       JS — all post-mortem rules applied:
       · DOMContentLoaded wrapper
       · addEventListener only, zero onclick
       · safe on() helper — no null crashes
       · try-catch on all localStorage
       · email rendered via JS (no raw HTML)
  ══════════════════════════════════════ -->
  <script>
  document.addEventListener('DOMContentLoaded', function () {

    /* ── helpers ── */
    function el(id) { return document.getElementById(id); }
    function on(id, ev, fn) { var e = el(id); if (e) e.addEventListener(ev, fn); }

    /* ── page switching ── */
    function showPage(n) {
      [1,2,3,4,5].forEach(function(i){ var p=el('page'+i); if(p) p.classList.toggle('active', i===n); });
      window.scrollTo({ top: 0, behavior: 'smooth' });
      el('mobileMenu').classList.remove('open');
      el('hamburger').classList.remove('open');
    }

    /* ── hamburger mobile menu ── */
    on('hamburger', 'click', function () {
      el('hamburger').classList.toggle('open');
      el('mobileMenu').classList.toggle('open');
    });
    on('mmHome',     'click', function () { showPage(1); });
    on('mmProducts', 'click', function () { showPage(2); });
    on('mmBlog',     'click', function () { showPage(4); });
    on('mmContact',  'click', function () { showPage(1); openModal('contact'); });
    on('mmCta',      'click', function () { openModal('buy'); });

    /* ── nav links ── */
    on('navLogo',     'click', function () { showPage(1); });
    on('navHome',     'click', function () { showPage(1); });
    on('navProducts', 'click', function () { showPage(2); });
    on('navFeatures', 'click', function () {
      showPage(1);
      setTimeout(function () { var s = el('features'); if (s) s.scrollIntoView({ behavior: 'smooth' }); }, 120);
    });
    on('navContact',  'click', function () { openModal('contact'); });
    on('navLearnMore','click', function () { showPage(2); });
    on('navCta',      'click', function () { openModal('buy'); });

    /* ── page 1 buttons ── */
    on('heroShop',      'click', function () { showPage(2); });
    on('heroLearn',     'click', function () { showPage(2); });
    on('previewCta',    'click', function () { showPage(2); });
    on('ctaBandShop',   'click', function () { showPage(2); });
    on('ctaBandContact','click', function () { openModal('contact'); });
    on('fp1','click', function(){ showPage(2); });
    on('fp2','click', function(){ showPage(2); });
    on('fp3','click', function(){ showPage(2); });
    on('fp4','click', function(){ showPage(2); });
    on('fContact','click', function(){ openModal('contact'); });
    on('fAbout','click',  function(){ openModal('contact'); });
    on('fBlog','click',   function(){ showPage(4); });
    on('fAffiliate','click', function(){ openModal('contact'); });

    /* ── page 2 buttons ── */
    on('p2CtaBack',    'click', function () { showPage(1); });
    on('p2CtaContact', 'click', function () { openModal('contact'); });

    /* ── product buy buttons — open detail page ── */
    var products = [
      { cat:'Playbook', name:'Make.com Automation Playbook', desc:'4 production-ready AI workflows — Instagram Handler, Content Engine, Lead Gen & Cold Outreach. Zero code. Instant results.', price:'₹299', inr:'₹299', strike:'₹599', save:'50%',
        features:['4 complete workflow blueprints','20+ module configuration reference','AI prompt templates for Claude & ChatGPT','Email sequence Day 0–Day 12','Quick-start launch checklist','30-day WhatsApp support'] },
      { cat:'Automation', name:'WhatsApp AI Responder', desc:'Apne WhatsApp pe AI laga do — leads ko auto-reply karo, qualify karo aur appointment book karo 24/7 bina kisi ke.', price:'₹499', inr:'₹499', strike:'₹999', save:'50%',
        features:['AI auto-reply — instant response','Leads automatically qualify ho','Appointment booking built-in','Google Sheets mein data log','30-day WhatsApp support included'] },
      { cat:'Content AI', name:'AI Content Engine', desc:'Ek ghante mein 30 din ka content banao — Instagram captions, emails, reels scripts. GPT-4 powered templates.', price:'₹349', inr:'₹349', strike:'₹699', save:'50%',
        features:['100+ ready-to-use templates','Instagram, LinkedIn, Email sab ke liye','Brand voice training included','Hashtag generator tool','Lifetime updates free'] },
      { cat:'Lead Generation', name:'Lead Capture System', desc:'Sote waqt bhi leads capture ho, qualify ho aur nurture ho. Landing page se WhatsApp follow-up tak poora funnel.', price:'₹599', inr:'₹599', strike:'₹1,199', save:'50%',
        features:['AI-powered landing page','7-email drip sequence','Lead scoring AI model','Auto WhatsApp follow-up','Analytics dashboard setup'] },
      { cat:'Automation', name:'Zapier Mega Pack', desc:'50+ ready-made Zapier workflows — import karo aur seedha chala do. E-commerce, agency, freelancer sab ke liye.', price:'₹199', inr:'₹199', strike:'₹399', save:'50%',
        features:['50+ import-ready workflows','CRM + email + sheets connect','Har workflow ka video guide','Slack + email notifications','Monthly naye workflows add'] },
      { cat:'Content AI', name:'Instagram Growth Kit', desc:'AI captions, hashtag strategy, story templates aur auto-DM bot — sab ek jagah. Reels se real followers tak.', price:'₹249', inr:'₹249', strike:'₹499', save:'50%',
        features:['30 din ke captions AI se','200+ story templates','Auto-DM bot setup guide','Hashtag research tool','Reel script templates'] },
      { cat:'Guide', name:'Complete AI Agent Builder Guide', desc:'ChatGPT + Claude se apna khud ka AI agent banao. 6 chapters, 15+ working code snippets, real proof ke saath. Bilkul beginner-friendly.', price:'₹399', inr:'₹399', strike:'₹799', save:'50%',
        features:['GPT-4o Function Calling Agent — full tested code','Claude Tool Use Agent + reasoning trace visible','Memory System — short-term aur long-term','Multi-Agent Orchestrator pattern — real code','Free deploy — Replit, Railway, Make.com webhook','100% Beginner friendly — copy-paste ready'] },
      { cat:'Bundle', name:'Complete AI Business Stack', desc:'Saare 7 products ek saath — automation, content, leads, agent guide aur playbook. White-label rights bhi included.', price:'₹999', inr:'₹999', strike:'₹2,499', save:'60%',
        features:['Saare 7 products included','White-label rights — resell kar sakte ho','Priority WhatsApp support (48h)','Onboarding call included','Quarterly updates for 1 year'] }
    ];

    document.querySelectorAll('.prod-buy').forEach(function (btn, i) {
      btn.addEventListener('click', function () { openDetailPage(i); });
    });

    // "View full details" on playbook card → page 5
    document.querySelectorAll('.playbook-detail-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { showPage(5); });
    });
    // "View details" on agent guide card → open modal
    document.querySelectorAll('.agent-detail-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { openModal('buy'); });
    });

    function openDetailPage(idx) {
      var p = products[idx] || products[0];
      el('detailCat').textContent   = p.cat;
      el('detailName').textContent  = p.name;
      el('detailDesc').textContent  = p.desc;
      el('detailPrice').textContent = p.price;
      el('detailBuyBtn').textContent = 'Buy now — ' + p.price;
      el('rpPrice').textContent     = p.inr;
      document.querySelector('.rp-strike').textContent = p.strike;
      document.querySelector('.rp-save').textContent   = 'Save ' + p.save;
      var featEl = el('detailFeatures');
      featEl.innerHTML = p.features.map(function(f){ return '<li>' + f + '</li>'; }).join('');
      // store current product for Razorpay
      el('rzpPayBtn').setAttribute('data-name', p.name);
      el('rzpPayBtn').setAttribute('data-price', p.price);
      showPage(3);
    }

    on('detailBackBtn', 'click', function () { showPage(2); });
    on('detailBuyBtn',  'click', function () { initRazorpay(); });

    /* ── Razorpay integration ── */
    on('rzpPayBtn', 'click', function () { initRazorpay(); });

    function initRazorpay() {
      var btn = el('rzpPayBtn');
      var name = btn.getAttribute('data-name') || 'SUFYX-AI Product';
      var priceText = btn.getAttribute('data-price') || '₹299';
      var inrAmount = parseInt(priceText.replace(/[₹,]/g,'')) || 299;
      var amountPaise = inrAmount * 100;

      // ─────────────────────────────────────────
      // 🔑 RAZORPAY SETUP (Step 2):
      // 1. razorpay.com pe free account banao
      // 2. Settings → API Keys → Generate Test Key
      // 3. Neeche 'rzp_test_XXXX' ki jagah apni key daalo
      // 4. Live ke liye: rzp_live_XXXX use karo
      // ─────────────────────────────────────────
      var RZP_KEY = 'rzp_test_REPLACE_YOUR_KEY_HERE';

      if (typeof Razorpay === 'undefined' || RZP_KEY.includes('REPLACE')) {
        // Fallback → WhatsApp se manually collect karo
        var msg = encodeURIComponent(
          'Hi Sufiyan! 🙏\n\nMujhe yeh product lena hai:\n' +
          '📦 Product: ' + name + '\n' +
          '💰 Price: ' + priceText + '\n\n' +
          'Payment details bhejo please!'
        );
        window.open('https://wa.me/919027108764?text=' + msg, '_blank');
        return;
      }

      btn.classList.add('loading');
      btn.textContent = 'Opening payment...';

      var options = {
        key: RZP_KEY,
        amount: amountPaise,
        currency: 'INR',
        name: 'SUFYX-AI',
        description: name,
        image: '',
        prefill: { name: '', email: '', contact: '' },
        theme: { color: '#1D1D1F' },
        handler: function (response) {
          btn.classList.remove('loading');
          btn.innerHTML = '<span>✅</span> Payment successful!';
          // Save order locally
          try {
            var orders = JSON.parse(localStorage.getItem('sufyx_orders') || '[]');
            orders.push({ product: name, price: priceText, paymentId: response.razorpay_payment_id, ts: new Date().toISOString() });
            localStorage.setItem('sufyx_orders', JSON.stringify(orders));
          } catch(e) {}
          // Redirect to WhatsApp for delivery
          setTimeout(function () {
            var deliveryMsg = encodeURIComponent('Payment successful! ID: ' + response.razorpay_payment_id + '. Please deliver: ' + name);
            window.open('https://wa.me/919027108764?text=' + deliveryMsg, '_blank');
          }, 1000);
        },
        modal: {
          ondismiss: function () {
            btn.classList.remove('loading');
            btn.innerHTML = '<span>🔒</span> Pay securely with Razorpay';
          }
        }
      };

      try {
        var rzp = new Razorpay(options);
        rzp.open();
      } catch(e) {
        btn.classList.remove('loading');
        btn.innerHTML = '<span>🔒</span> Pay securely with Razorpay';
        // Fallback to WhatsApp
        var m = encodeURIComponent('Hi! I want to buy: ' + name + ' (' + priceText + '). Please send me the payment link.');
        window.open('https://wa.me/919027108764?text=' + m, '_blank');
      }
    }

    /* ── category filter (page 2) ── */
    document.querySelectorAll('.cat-pill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        document.querySelectorAll('.cat-pill').forEach(function (p) { p.classList.remove('active'); });
        pill.classList.add('active');
        var cat = pill.getAttribute('data-cat');
        document.querySelectorAll('.prod-card').forEach(function (card) {
          card.style.display = (cat === 'all' || card.getAttribute('data-cat') === cat) ? 'flex' : 'none';
        });
      });
    });

    /* ── FAQ accordion ── */
    document.querySelectorAll('.faq-q').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.faq-item');
        var wasOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(function (i) { i.classList.remove('open'); });
        if (!wasOpen) item.classList.add('open');
      });
    });

    /* ── blog nav ── */
    on('navBlog', 'click', function () { showPage(4); });
    document.querySelectorAll('.blog-card').forEach(function (card) {
      card.addEventListener('click', function () { openModal('contact'); }); // placeholder for full post
    });
    on('blogFooterHome',     'click', function () { showPage(1); });
    on('blogFooterProducts', 'click', function () { showPage(2); });
    on('p5FooterHome',       'click', function () { showPage(1); });
    on('p5FooterProducts',   'click', function () { showPage(2); });
    on('playbackBackBtn',    'click', function () { showPage(2); });
    document.querySelectorAll('.playbook-buy-btn').forEach(function(btn){
      btn.addEventListener('click', function(){ openModal('buy'); });
    });

    /* ── modal ── */
    function openModal(type) {
      if (type === 'buy') {
        el('modalEyebrow').textContent = 'Purchase enquiry';
        el('modalTitle').textContent   = 'Get this product';
        el('modalDesc').textContent    = "Tell us which product you want and we'll send you the secure payment link via WhatsApp.";
      } else {
        el('modalEyebrow').textContent = 'Contact us';
        el('modalTitle').textContent   = "Let's talk";
        el('modalDesc').textContent    = "Fill in your details and we'll reach out via WhatsApp within 24 hours.";
      }
      el('modalForm').style.display = 'block';
      el('modalSuccess').classList.remove('show');
      el('modalOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      el('modalOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    on('modalClose', 'click', closeModal);
    el('modalOverlay').addEventListener('click', function (e) { if (e.target === this) closeModal(); });

    on('modalSubmit', 'click', async function () {
      var name    = el('mName').value.trim();
      var email   = el('mEmail').value.trim();
      var product = el('mProduct').value;
      if (!name)               { el('mName').style.borderColor  = '#FF3B30'; el('mName').focus();  return; }
      if (!email.includes('@')){ el('mEmail').style.borderColor = '#FF3B30'; el('mEmail').focus(); return; }

      el('modalSubmit').disabled = true;
      el('modalSubmit').textContent = 'Sending...';

      // ─────────────────────────────────────────────
      // 📧 FIX #4 — FORMSPREE EMAIL SETUP:
      // 1. formspree.io pe free account banao
      // 2. New form banao → apna endpoint copy karo
      // 3. 'YOUR_FORMSPREE_ID' ki jagah daalo (e.g. 'xpwzgkjb')
      // ─────────────────────────────────────────────
      var FORMSPREE_ID = 'YOUR_FORMSPREE_ID';

      // Save to localStorage
      try {
        var leads = JSON.parse(localStorage.getItem('sufyx_leads') || '[]');
        leads.push({ name: name, email: email, product: product, ts: new Date().toISOString() });
        localStorage.setItem('sufyx_leads', JSON.stringify(leads));
      } catch (e) {}

      // Send to Formspree (if configured)
      if (!FORMSPREE_ID.includes('YOUR')) {
        try {
          await fetch('https://formspree.io/f/' + FORMSPREE_ID, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({
              name: name, email: email,
              product: product || 'Not specified',
              source: 'SUFYX-AI Purchase Enquiry',
              _subject: '🛒 New Purchase Enquiry — ' + (product || 'SUFYX-AI')
            })
          });
        } catch(e) {}
      }

      // Always open WhatsApp with prefilled message
      var waMsg = encodeURIComponent(
        'Hi! 👋\n\nNaaya order hai:\n' +
        '👤 Name: ' + name + '\n' +
        '📧 Email: ' + email + '\n' +
        '📦 Product: ' + (product || 'Not selected') + '\n\n' +
        'Payment link bhejo please!'
      );
      window.open('https://wa.me/919027108764?text=' + waMsg, '_blank');

      el('modalSubmit').disabled = false;
      el('modalSubmit').textContent = 'Send enquiry';
      el('modalForm').style.display = 'none';
      el('modalSuccess').classList.add('show');
    });

    /* ── ESC to close ── */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeModal();
    });

  });
  </script>

  <!-- Razorpay SDK — loaded async, graceful fallback if offline -->
  <script src="https://checkout.razorpay.com/v1/checkout.js" async></script>

  <!-- ══════════════════════════════════════
       AI CHATBOT — SUFYX-AI Support
  ══════════════════════════════════════ -->
  <style>
    /* CHAT BUBBLE */
    .chat-bubble {
      position: fixed; bottom: 24px; left: 24px; z-index: 800;
      width: 52px; height: 52px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #2563EB);
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 20px rgba(0,113,227,0.45);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .chat-bubble:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(0,113,227,0.55); }
    .chat-bubble svg { width: 24px; height: 24px; fill: #fff; }
    .chat-notif {
      position: absolute; top: -3px; right: -3px;
      width: 14px; height: 14px; border-radius: 50%;
      background: #FF375F; border: 2px solid var(--bg);
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot { 0%,100%{transform:scale(1);}50%{transform:scale(1.2);} }

    /* CHAT WINDOW */
    .chat-window {
      position: fixed;
      bottom: 90px;
      left: 24px;
      z-index: 800;
      width: 340px;
      height: 500px;
      background: var(--bg2);
      border: 1px solid var(--rule);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      display: flex;
      flex-direction: column;
      transform: scale(0.85) translateY(20px);
      transform-origin: bottom left;
      opacity: 0;
      pointer-events: none;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .chat-window.open {
      transform: scale(1) translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    /* CHAT HEADER — fixed height */
    .chat-header {
      flex-shrink: 0;
      background: linear-gradient(135deg, var(--dark), #1a1a2e);
      padding: 12px 16px;
      display: flex; align-items: center; gap: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .chat-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #2563EB);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; flex-shrink: 0;
    }
    .chat-header-info { flex: 1; }
    .chat-header-name { font-size: 0.85rem; font-weight: 700; color: #fff; }
    .chat-header-status {
      font-size: 0.65rem; color: var(--green);
      display: flex; align-items: center; gap: 5px;
    }
    .chat-header-status::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--green); animation: pulse-dot 2s infinite;
    }
    .chat-close {
      background: rgba(255,255,255,0.08); border: none; border-radius: 8px;
      color: rgba(255,255,255,0.5); width: 28px; height: 28px;
      cursor: pointer; font-size: 0.8rem; display: flex;
      align-items: center; justify-content: center;
      transition: background 0.15s, color 0.15s; flex-shrink: 0;
    }
    .chat-close:hover { background: rgba(255,255,255,0.15); color: #fff; }

    /* MESSAGES AREA — scrollable, takes remaining space */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      background: var(--bg);
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
    }
    .chat-messages::-webkit-scrollbar { width: 3px; }
    .chat-messages::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 3px; }

    /* MESSAGE BUBBLES */
    .msg { display: flex; gap: 8px; animation: msgIn 0.2s ease; }
    @keyframes msgIn { from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);} }
    .msg.user { flex-direction: row-reverse; }
    .msg-avatar {
      width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700; align-self: flex-end;
    }
    .msg-avatar.bot { background: linear-gradient(135deg, var(--accent), #2563EB); color: #fff; }
    .msg-avatar.user { background: linear-gradient(135deg, var(--accent2), #7c3aed); color: #fff; }
    .msg-bubble {
      max-width: 78%; padding: 9px 12px; border-radius: 14px;
      font-size: 0.82rem; line-height: 1.55; word-break: break-word;
    }
    .msg.bot .msg-bubble {
      background: var(--card); color: var(--dark); border: 1px solid var(--rule);
      border-bottom-left-radius: 4px;
    }
    .msg.user .msg-bubble {
      background: linear-gradient(135deg, var(--accent), #2563EB);
      color: #fff; border-bottom-right-radius: 4px;
    }
    .msg-time { font-size: 0.58rem; color: var(--muted); margin-top: 3px; text-align: right; }

    /* TYPING INDICATOR */
    .typing-indicator { display: none; flex-shrink: 0; }
    .typing-indicator.show { display: flex; }
    .typing-dots { display: flex; gap: 4px; align-items: center; padding: 9px 12px; background: var(--card); border: 1px solid var(--rule); border-radius: 14px; border-bottom-left-radius: 4px; }
    .typing-dots span { width: 5px; height: 5px; border-radius: 50%; background: var(--muted); animation: typing 1.2s infinite; }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typing { 0%,60%,100%{transform:translateY(0);opacity:0.4;}30%{transform:translateY(-4px);opacity:1;} }

    /* QUICK REPLIES — fixed, no scroll */
    .quick-replies {
      flex-shrink: 0;
      padding: 7px 12px;
      display: flex; gap: 6px; flex-wrap: wrap;
      background: var(--bg);
      border-top: 1px solid var(--rule);
    }
    .qr-btn {
      background: var(--card); border: 1px solid var(--rule);
      border-radius: 980px; padding: 5px 11px;
      font-size: 0.7rem; color: var(--accent); cursor: pointer;
      font-family: 'DM Sans', sans-serif; font-weight: 500;
      transition: all 0.15s; white-space: nowrap;
    }
    .qr-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* INPUT AREA — fixed at bottom */
    .chat-input-wrap {
      flex-shrink: 0;
      padding: 10px 12px;
      border-top: 1px solid var(--rule);
      display: flex; gap: 8px; align-items: center;
      background: var(--bg2);
    }
    .chat-input {
      flex: 1; background: var(--bg); border: 1.5px solid var(--rule);
      border-radius: 10px; padding: 8px 12px;
      font-family: 'DM Sans', sans-serif; font-size: 0.83rem;
      color: var(--dark); outline: none; resize: none;
      max-height: 70px; line-height: 1.4;
      transition: border-color 0.15s;
    }
    .chat-input:focus { border-color: var(--accent); }
    .chat-input::placeholder { color: var(--muted); }
    .chat-send {
      width: 34px; height: 34px; border-radius: 9px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--accent), #2563EB);
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.15s, transform 0.1s;
    }
    .chat-send:hover { opacity: 0.88; transform: scale(1.05); }
    .chat-send:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .chat-send svg { width: 15px; height: 15px; fill: #fff; }

    /* MOBILE — full screen chat */
    @media(max-width: 480px) {
      .chat-window {
        width: calc(100vw - 20px);
        left: 10px;
        right: 10px;
        bottom: 90px;
        height: 65vh;
        max-height: 520px;
      }
      .chat-bubble {
        bottom: 24px;
        left: 16px;
      }
    }
  </style>

  <!-- CHAT BUBBLE BUTTON -->
  <button class="chat-bubble" id="chatBubble" aria-label="Open Support Chat">
    <div class="chat-notif"></div>
    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
  </button>

  <!-- CHAT WINDOW -->
  <div class="chat-window" id="chatWindow">
    <!-- Header -->
    <div class="chat-header">
      <div class="chat-avatar">🤖</div>
      <div class="chat-header-info">
        <div class="chat-header-name">SUFYX-AI Assistant</div>
        <div class="chat-header-status">Online — AI Powered</div>
      </div>
      <button class="chat-close" id="chatClose">✕</button>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chatMessages">
      <div class="msg bot">
        <div class="msg-avatar bot">🤖</div>
        <div>
          <div class="msg-bubble">Namaste! 👋 Main SUFYX-AI ka support assistant hoon.<br><br>Mujhse poochho — products, pricing, payment, ya kuch bhi!</div>
          <div class="msg-time">Just now</div>
        </div>
      </div>
    </div>

    <!-- Typing indicator -->
    <div class="msg bot typing-indicator" id="typingIndicator" style="padding:0 16px 8px;">
      <div class="msg-avatar bot">🤖</div>
      <div class="typing-dots"><span></span><span></span><span></span></div>
    </div>

    <!-- Quick replies -->
    <div class="quick-replies" id="quickReplies">
      <button class="qr-btn">📦 Products dekhna hai</button>
      <button class="qr-btn">💳 Payment kaise karein?</button>
      <button class="qr-btn">🤖 AI Agent Guide kya hai?</button>
      <button class="qr-btn">📄 Make.com Playbook?</button>
      <button class="qr-btn">🔄 Refund policy?</button>
    </div>

    <!-- Input -->
    <div class="chat-input-wrap">
      <textarea class="chat-input" id="chatInput" placeholder="Apna sawal yahan likhein..." rows="1"></textarea>
      <button class="chat-send" id="chatSend">
        <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function () {

    var chatBubble  = document.getElementById('chatBubble');
    var chatWindow  = document.getElementById('chatWindow');
    var chatClose   = document.getElementById('chatClose');
    var chatMessages= document.getElementById('chatMessages');
    var chatInput   = document.getElementById('chatInput');
    var chatSend    = document.getElementById('chatSend');
    var typingEl    = document.getElementById('typingIndicator');
    var quickEl     = document.getElementById('quickReplies');
    var isOpen      = false;
    var isLoading   = false;

    // Chat history for context
    var chatHistory = [];

    // SUFYX-AI product knowledge base (system prompt)
    var systemPrompt = `You are a friendly and helpful customer support assistant for SUFYX-AI — an Indian digital products company that sells AI automation tools and guides.

PRODUCTS & PRICING (all prices in INR, one-time payment):
1. Make.com Automation Playbook — ₹299 (was ₹599) — 4 AI workflows, 20+ modules, no-code
2. WhatsApp AI Responder — ₹499 (was ₹999) — auto-reply bot, lead qualification, appointment booking
3. AI Content Engine — ₹349 (was ₹699) — 100+ templates, Instagram/LinkedIn/Email content
4. Lead Capture System — ₹599 (was ₹1,199) — AI funnel, email drip, lead scoring
5. Zapier Mega Pack — ₹199 (was ₹399) — 50+ ready workflows
6. Instagram Growth Kit — ₹249 (was ₹499) — captions, stories, auto-DM
7. AI Agent Builder Guide — ₹399 (was ₹799) — ChatGPT + Claude agents, 6 chapters, 15+ code snippets
8. Complete AI Business Stack Bundle — ₹999 (was ₹2,499) — all 7 products + white-label rights

POLICIES:
- All products: one-time payment, lifetime access, all future updates free
- 7-day money-back guarantee on all products
- Payment via UPI, Visa, Mastercard, RuPay, Net Banking (Razorpay)
- WhatsApp support: +91 90271 08764
- Instagram: @sufiyann_9027
- Email: zyntaskai@gmail.com
- Response time: within 24 hours on WhatsApp

ABOUT:
- Founder: Sufiyan — self-taught AI automation builder from a village in India
- Built with EDITH (Claude AI)

TONE: Be friendly, helpful, and use a mix of Hindi and English (Hinglish) naturally. Keep responses concise and helpful. If someone wants to buy, guide them to click "Buy now" or contact on WhatsApp. Always end with offering more help.`;

    // Toggle chat
    chatBubble.addEventListener('click', function () {
      isOpen = !isOpen;
      chatWindow.classList.toggle('open', isOpen);
      if (isOpen) {
        chatBubble.querySelector('.chat-notif').style.display = 'none';
        chatInput.focus();
      }
    });

    chatClose.addEventListener('click', function () {
      isOpen = false;
      chatWindow.classList.remove('open');
    });

    // Quick replies
    quickEl.querySelectorAll('.qr-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        sendMessage(btn.textContent.trim());
        quickEl.style.display = 'none';
      });
    });

    // Send on Enter (Shift+Enter for new line)
    chatInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage(chatInput.value.trim());
      }
    });
    chatSend.addEventListener('click', function () {
      sendMessage(chatInput.value.trim());
    });

    // Auto-resize textarea
    chatInput.addEventListener('input', function () {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 80) + 'px';
    });

    function getTime() {
      var d = new Date();
      return d.getHours() + ':' + String(d.getMinutes()).padStart(2,'0');
    }

    function addMessage(text, role) {
      var isUser = role === 'user';
      var div = document.createElement('div');
      div.className = 'msg ' + role;
      div.innerHTML =
        '<div class="msg-avatar ' + role + '">' + (isUser ? 'U' : '🤖') + '</div>' +
        '<div>' +
          '<div class="msg-bubble">' + text.replace(/\n/g, '<br>') + '</div>' +
          '<div class="msg-time">' + getTime() + '</div>' +
        '</div>';
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showTyping(show) {
      typingEl.classList.toggle('show', show);
      if (show) chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    async function sendMessage(text) {
      if (!text || isLoading) return;
      chatInput.value = '';
      chatInput.style.height = 'auto';
      isLoading = true;
      chatSend.disabled = true;

      // Add user message
      addMessage(text, 'user');
      chatHistory.push({ role: 'user', content: text });

      // Show typing
      showTyping(true);

      try {
        var response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            model: 'claude-sonnet-4-20250514',
            max_tokens: 400,
            system: systemPrompt,
            messages: chatHistory
          })
        });

        var data = await response.json();
        var reply = (data.content && data.content[0] && data.content[0].text)
          ? data.content[0].text
          : 'Maafi chahta hoon, abhi thodi dikkat aa rahi hai. Please WhatsApp karein: +91 90271 08764 🙏';

        // Add to history
        chatHistory.push({ role: 'assistant', content: reply });

        // Keep history to last 10 messages (5 exchanges)
        if (chatHistory.length > 10) chatHistory = chatHistory.slice(-10);

        showTyping(false);
        addMessage(reply, 'bot');

      } catch (err) {
        showTyping(false);
        addMessage('Oops! Network issue lag raha hai. Please WhatsApp pe message karein: +91 90271 08764 💬', 'bot');
      }

      isLoading = false;
      chatSend.disabled = false;
      chatInput.focus();
    }

  });
  </script>
</body>
</html>
