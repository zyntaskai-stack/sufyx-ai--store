  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"SUFYX-AI","url":"https://sufyx.ai","description":"Premium AI digital products for business automation","contactPoint":{"@type":"ContactPoint","telephone":"+91-90271-08764","contactType":"customer support"},"sameAs":["https://www.instagram.com/sufiyann_9027"]}</script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    /* ═══════════════════════════════════════
       DESIGN TOKENS — all colours here only
    ═══════════════════════════════════════ */
    :root {
      --bg:       #F5F5F7;
      --bg2:      #FFFFFF;
      --bg3:      #000000;
      --surface:  #FBFBFD;
      --card:     #FFFFFF;
      --dark:     #1D1D1F;
      --mid:      #424245;
      --muted:    #6E6E73;
      --rule:     #D2D2D7;
      --accent:   #0071E3;
      --accent-h: #0077ED;
      --green:    #34C759;
      --gold:     #FF9F0A;
      --pink:     #FF375F;

      --r-sm:  12px;
      --r-md:  18px;
      --r-lg:  28px;
      --r-xl:  40px;
    }

    /* ═══════════════════════════════════════
       RESET & BASE
    ═══════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body {
      background: var(--bg);
      color: var(--dark);
      font-family: 'DM Sans', sans-serif;
      font-size: 17px;
      line-height: 1.47;
      overflow-x: hidden;
    }

    /* ═══════════════════════════════════════
       TYPOGRAPHY SCALE
    ═══════════════════════════════════════ */
    .t-hero   { font-family: 'DM Serif Display', serif; font-size: clamp(3rem, 7vw, 6.5rem); line-height: 1.04; letter-spacing: -0.02em; color: var(--dark); }
    .t-hero em{ font-style: italic; color: var(--accent); }
    .t-title  { font-family: 'DM Serif Display', serif; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.1; letter-spacing: -0.015em; color: var(--dark); }
    .t-title em{ font-style: italic; }
    .t-section{ font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
    .t-body   { font-size: 1.05rem; color: var(--muted); line-height: 1.7; }
    .t-label  { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }

    /* ═══════════════════════════════════════
       BUTTON HIERARCHY
       Primary → ghost → text (from post-mortem)
    ═══════════════════════════════════════ */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.95rem;
      border-radius: 980px; cursor: pointer; text-decoration: none;
      transition: opacity 0.15s, transform 0.1s, background 0.15s;
      white-space: nowrap; border: none;
    }
    .btn-primary   { background: var(--accent); color: #fff; padding: 12px 26px; }
    .btn-primary:hover { background: var(--accent-h); transform: scale(1.02); }
    .btn-ghost     { background: transparent; color: var(--accent); padding: 12px 26px; border: 1.5px solid rgba(0,113,227,0.35); }
    .btn-ghost:hover { background: rgba(0,113,227,0.06); }
    .btn-dark      { background: var(--dark); color: #fff; padding: 12px 26px; }
    .btn-dark:hover{ background: #3a3a3c; transform: scale(1.02); }
    .btn-white     { background: #fff; color: var(--dark); padding: 12px 26px; }
    .btn-white:hover{ background: #f0f0f2; transform: scale(1.02); }
    .btn-text      { background: transparent; color: var(--accent); padding: 0; font-size: 0.95rem; border: none; text-decoration: none; }
    .btn-text::after { content: ' →'; }
    .btn-text:hover { opacity: 0.75; }
    .btn-sm        { padding: 9px 18px; font-size: 0.85rem; }

    /* ═══════════════════════════════════════
       NAV — Apple-style frosted glass
    ═══════════════════════════════════════ */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 900;
      height: 48px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 22px;
      background: rgba(245,245,247,0.85);
      backdrop-filter: saturate(180%) blur(20px);
      -webkit-backdrop-filter: saturate(180%) blur(20px);
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .nav-logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.15rem; letter-spacing: -0.01em; color: var(--dark); cursor: pointer;
    }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 28px; }
    .nav-links a {
      font-size: 0.82rem; color: var(--mid); text-decoration: none;
      cursor: pointer; transition: color 0.15s; letter-spacing: 0.01em;
    }
    .nav-links a:hover { color: var(--dark); }
    .nav-right { display: flex; align-items: center; gap: 10px; }
    .nav-cta { font-size: 0.82rem; padding: 7px 16px; }

    @media(max-width:700px){
      .nav-links { display: none; }
    }

    /* ── MOBILE HAMBURGER ── */
    .hamburger {
      display: none; flex-direction: column; gap: 4px;
      background: none; border: none; cursor: pointer; padding: 4px;
    }
    .hamburger span {
      display: block; width: 20px; height: 2px;
      background: var(--dark); border-radius: 2px;
      transition: all 0.2s;
    }
    .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }
    @media(max-width:700px) {
      .hamburger { display: flex; }
      .nav-right .btn-text { display: none; }
    }
    .mobile-menu {
      display: none; position: fixed; top: 48px; left: 0; right: 0;
      background: rgba(245,245,247,0.97); backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--rule); z-index: 899;
      flex-direction: column; padding: 16px 22px 20px;
    }
    .mobile-menu.open { display: flex; animation: fadeIn 0.15s ease; }
    .mobile-menu a {
      padding: 13px 0; font-size: 1rem; color: var(--dark);
      border-bottom: 1px solid var(--rule); cursor: pointer;
      font-weight: 500; text-decoration: none;
    }
    .mobile-menu a:last-child { border-bottom: none; }
    .mobile-menu .btn { margin-top: 16px; width: 100%; justify-content: center; }

    /* ── WHATSAPP FLOAT BUTTON ── */
    .wa-float {
      position: fixed; bottom: 24px; right: 24px; z-index: 800;
      width: 54px; height: 54px; border-radius: 50%;
      background: #25D366; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,0.45);
      transition: transform 0.15s, box-shadow 0.15s;
      text-decoration: none;
    }
    .wa-float:hover { transform: scale(1.1); box-shadow: 0 6px 28px rgba(37,211,102,0.55); }
    .wa-float svg { width: 28px; height: 28px; fill: #fff; }
    .wa-tooltip {
      position: absolute; right: 64px; background: var(--dark);
      color: #fff; font-size: 0.75rem; font-weight: 500;
      padding: 6px 12px; border-radius: 8px; white-space: nowrap;
      opacity: 0; pointer-events: none; transition: opacity 0.15s;
    }
    .wa-float:hover .wa-tooltip { opacity: 1; }

    /* ── PRODUCT DETAIL PAGE (page3) ── */
    .prod-detail-hero {
      padding: 100px 24px 60px; text-align: center;
      background: linear-gradient(180deg, #fff 0%, var(--bg) 100%);
    }
    .prod-detail-hero .t-section { margin-bottom: 10px; }
    .prod-detail-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.2rem,5vw,4rem); letter-spacing: -0.02em; margin-bottom: 14px; }
    .prod-detail-hero .t-body { max-width: 560px; margin: 0 auto 32px; font-size: 1.1rem; }
    .prod-detail-hero .price-tag { font-family: 'DM Serif Display', serif; font-size: 3rem; color: var(--dark); margin-bottom: 6px; }
    .prod-detail-hero .price-note { font-size: 0.82rem; color: var(--muted); margin-bottom: 28px; }
    .detail-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    .detail-body { max-width: 1100px; margin: 0 auto; padding: 60px 24px 100px; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
    .detail-section-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 20px; color: var(--dark); }
    .detail-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .detail-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.95rem; color: var(--mid); line-height: 1.6; }
    .detail-list li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .detail-steps { display: flex; flex-direction: column; gap: 0; }
    .detail-step { display: grid; grid-template-columns: 40px 1fr; gap: 16px; padding: 20px 0; border-bottom: 1px solid var(--rule); align-items: start; }
    .detail-step:last-child { border-bottom: none; }
    .detail-step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--dark); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0; }
    .detail-step h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; }
    .detail-step p  { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

    .razorpay-box {
      background: #fff; border: 1px solid var(--rule); border-radius: var(--r-xl);
      padding: 36px 32px; margin-top: 40px;
    }
    .razorpay-box h3 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; margin-bottom: 6px; }
    .razorpay-box p  { font-size: 0.88rem; color: var(--muted); margin-bottom: 24px; }
    .razorpay-price-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 20px; }
    .rp-price { font-family: 'DM Serif Display', serif; font-size: 2.5rem; color: var(--dark); }
    .rp-strike { font-size: 1.1rem; color: var(--muted); text-decoration: line-through; }
    .rp-save { font-size: 0.8rem; background: #dcfce7; color: #166534; padding: 3px 10px; border-radius: 980px; font-weight: 600; }
    .rp-features { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
    .rp-feat { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; color: var(--mid); }
    .rp-feat::before { content: '✓'; color: var(--green); font-weight: 700; }
    .rp-btn {
      width: 100%; padding: 15px; background: var(--dark); color: #fff;
      border: none; border-radius: 980px; font-family: 'DM Sans', sans-serif;
      font-weight: 600; font-size: 1rem; cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .rp-btn:hover { background: #3a3a3c; transform: scale(1.01); }
    .rp-btn.loading { opacity: 0.6; pointer-events: none; }
    .rp-note { text-align: center; font-size: 0.72rem; color: var(--muted); margin-top: 10px; }
    .rp-logos { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 14px; opacity: 0.5; font-size: 0.7rem; color: var(--muted); letter-spacing: 0.05em; }

    @media(max-width:700px) {
      .detail-grid { grid-template-columns: 1fr; gap: 32px; }
    }

    /* ── BLOG PAGE (page4) ── */
    .blog-hero {
      padding: 120px 24px 60px; background: var(--bg3); text-align: center;
    }
    .blog-hero .t-section { color: rgba(255,255,255,0.4); margin-bottom: 12px; }
    .blog-hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.5rem,6vw,5rem); color: #fff; letter-spacing: -0.03em; margin-bottom: 14px; }
    .blog-hero p  { color: rgba(255,255,255,0.55); font-size: 1rem; max-width: 480px; margin: 0 auto; }

    .blog-grid-wrap { max-width: 1100px; margin: 0 auto; padding: 70px 24px 100px; }
    .blog-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
    .blog-card {
      background: var(--card); border: 1px solid var(--rule); border-radius: var(--r-lg);
      overflow: hidden; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
    }
    .blog-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
    .blog-thumb {
      aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;
      font-size: 2.8rem;
    }
    .blog-body { padding: 22px 20px; }
    .blog-tag { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
    .blog-title { font-family: 'DM Serif Display', serif; font-size: 1.15rem; color: var(--dark); line-height: 1.3; margin-bottom: 8px; }
    .blog-excerpt { font-size: 0.83rem; color: var(--muted); line-height: 1.65; margin-bottom: 14px; }
    .blog-meta { font-size: 0.72rem; color: var(--muted); display: flex; justify-content: space-between; }

    @media(max-width:760px){ .blog-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:480px){ .blog-grid { grid-template-columns: 1fr; } }

    /* ═══════════════════════════════════════
       PAGES
    ═══════════════════════════════════════ */
    .page { display: none; }
    .page.active { display: block; }

    /* ═══════════════════════════════════════
       ── PAGE 1: HOME ──
    ═══════════════════════════════════════ */

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; padding: 100px 24px 80px;
      background: linear-gradient(180deg, #FFFFFF 0%, #F5F5F7 60%);
      position: relative; overflow: hidden;
    }
    .hero-glow {
      position: absolute; width: 700px; height: 700px; border-radius: 50%;
      background: radial-gradient(circle, rgba(0,113,227,0.07) 0%, transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%,-55%);
      pointer-events: none;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(0,113,227,0.08); border: 1px solid rgba(0,113,227,0.18);
      border-radius: 980px; padding: 5px 14px;
      font-size: 0.78rem; font-weight: 600; color: var(--accent);
      letter-spacing: 0.04em; margin-bottom: 28px;
      animation: fadeUp 0.35s ease both;
    }
    .hero-eyebrow::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
      animation: blink 2s infinite;
    }
    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.2;} }

    .hero h1 { animation: fadeUp 0.35s 0.05s ease both; margin-bottom: 22px; max-width: 860px; }
    .hero-sub {
      max-width: 560px; font-size: 1.18rem; color: var(--muted); line-height: 1.6;
      margin-bottom: 40px; animation: fadeUp 0.35s 0.1s ease both;
    }
    .hero-actions {
      display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
      animation: fadeUp 0.35s 0.15s ease both; margin-bottom: 60px;
    }
    .hero-social-proof {
      display: flex; align-items: center; gap: 16px;
      animation: fadeUp 0.35s 0.2s ease both;
    }
    .proof-avatars { display: flex; }
    .proof-avatars span {
      width: 32px; height: 32px; border-radius: 50%; border: 2px solid #fff;
      background: linear-gradient(135deg, #667eea, #764ba2);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; color: #fff; font-weight: 700;
      margin-left: -8px;
    }
    .proof-avatars span:first-child { margin-left: 0; }
    .proof-text { font-size: 0.82rem; color: var(--muted); }
    .proof-text strong { color: var(--dark); }

    @keyframes fadeUp { from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);} }

    /* PRODUCT PREVIEW */
    .preview-section {
      background: var(--bg3); padding: 0;
      overflow: hidden; position: relative;
    }
    .preview-inner {
      max-width: 1200px; margin: 0 auto; padding: 100px 24px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    .preview-text .t-section { margin-bottom: 14px; color: rgba(255,255,255,0.5); }
    .preview-text .t-title   { color: #fff; margin-bottom: 18px; }
    .preview-text .t-body    { color: rgba(255,255,255,0.6); margin-bottom: 32px; }
    .preview-mockup {
      background: linear-gradient(135deg, #1c1c1e, #2c2c2e);
      border-radius: var(--r-xl); border: 1px solid rgba(255,255,255,0.1);
      padding: 32px; aspect-ratio: 4/3;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .mock-bar { display: flex; gap: 6px; margin-bottom: 20px; }
    .mock-dot { width: 10px; height: 10px; border-radius: 50%; }
    .mock-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; flex: 1; }
    .mock-card {
      background: rgba(255,255,255,0.06); border-radius: 12px; padding: 14px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .mock-line { height: 6px; border-radius: 3px; background: rgba(255,255,255,0.12); }
    .mock-line.w80 { width: 80%; }
    .mock-line.w60 { width: 60%; }
    .mock-line.w40 { width: 40%; }
    .mock-stat { font-size: 1.4rem; font-weight: 700; color: #fff; }

    @media(max-width:760px){
      .preview-inner { grid-template-columns: 1fr; gap: 40px; }
    }

    /* FEATURE GRID */
    .features-section {
      max-width: 1200px; margin: 0 auto; padding: 100px 24px;
    }
    .features-header { text-align: center; margin-bottom: 64px; }
    .features-header .t-section { margin-bottom: 12px; }
    .features-header .t-title   { margin-bottom: 14px; }

    .feat-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
      border-radius: var(--r-lg); overflow: hidden;
      border: 1px solid var(--rule);
    }
    .feat-tile {
      background: var(--card); padding: 44px 36px;
      transition: background 0.15s;
    }
    .feat-tile:hover { background: #f0f4ff; }
    .feat-tile:nth-child(4), .feat-tile:nth-child(5), .feat-tile:nth-child(6) {
      border-top: 1px solid var(--rule);
    }
    .feat-icon {
      width: 52px; height: 52px; border-radius: 14px; margin-bottom: 20px;
      display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
    }
    .feat-name { font-size: 1.1rem; font-weight: 600; color: var(--dark); margin-bottom: 8px; }
    .feat-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    @media(max-width:860px){
      .feat-grid { grid-template-columns: 1fr 1fr; }
      .feat-tile:nth-child(3){ border-top: 1px solid var(--rule); }
    }
    @media(max-width:540px){
      .feat-grid { grid-template-columns: 1fr; }
      .feat-tile:nth-child(n+2){ border-top: 1px solid var(--rule); }
    }

    /* NUMBERS */
    .numbers-section {
      background: var(--dark); padding: 80px 24px;
    }
    .numbers-inner {
      max-width: 1000px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 2px;
    }
    .num-cell { text-align: center; padding: 40px 20px; }
    .num-val {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.5rem, 5vw, 4rem); color: #fff;
      letter-spacing: -0.03em; margin-bottom: 8px;
    }
    .num-val span { color: var(--accent); }
    .num-lbl { font-size: 0.82rem; color: rgba(255,255,255,0.45); letter-spacing: 0.05em; text-transform: uppercase; font-weight: 500; }

    @media(max-width:640px){
      .numbers-inner { grid-template-columns: 1fr 1fr; }
    }

    /* TESTIMONIALS */
    .testimonials-section {
      max-width: 1200px; margin: 0 auto; padding: 100px 24px;
    }
    .testi-header { text-align: center; margin-bottom: 60px; }
    .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .testi-card {
      background: var(--card); border: 1px solid var(--rule);
      border-radius: var(--r-lg); padding: 32px 28px;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .testi-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
    .testi-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 14px; }
    .testi-text { font-size: 0.95rem; color: var(--mid); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.8rem; color: #fff;
    }
    .testi-name { font-size: 0.88rem; font-weight: 600; color: var(--dark); }
    .testi-role { font-size: 0.78rem; color: var(--muted); }

    @media(max-width:760px){ .testi-grid { grid-template-columns: 1fr; } }

    /* CTA BAND */
    .cta-band {
      background: var(--accent); padding: 80px 24px; text-align: center;
    }
    .cta-band h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(1.8rem, 4vw, 3rem); color: #fff;
      letter-spacing: -0.02em; margin-bottom: 14px;
    }
    .cta-band p { color: rgba(255,255,255,0.8); margin-bottom: 32px; font-size: 1.05rem; }
    .cta-band-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    /* ═══════════════════════════════════════
       ── PAGE 2: PRODUCTS ──
    ═══════════════════════════════════════ */
    .products-hero {
      background: var(--bg3); padding: 130px 24px 80px; text-align: center;
    }
    .products-hero .t-section { color: rgba(255,255,255,0.45); margin-bottom: 14px; }
    .products-hero .t-hero    { color: #fff; margin-bottom: 18px; }
    .products-hero .t-body    { color: rgba(255,255,255,0.6); max-width: 520px; margin: 0 auto 40px; }

    .product-cats {
      display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;
      margin-bottom: 0;
    }
    .cat-pill {
      font-size: 0.82rem; padding: 7px 18px; border-radius: 980px; cursor: pointer;
      border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.6);
      background: transparent; font-family: 'DM Sans', sans-serif;
      transition: all 0.15s;
    }
    .cat-pill.active, .cat-pill:hover { background: #fff; color: var(--dark); border-color: #fff; }

    /* PRODUCT CARDS */
    .products-grid-section {
      max-width: 1200px; margin: 0 auto; padding: 80px 24px;
    }
    .products-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
    }
    .prod-card {
      background: var(--card); border: 1px solid var(--rule); border-radius: var(--r-xl);
      overflow: hidden; transition: transform 0.15s, box-shadow 0.15s;
      display: flex; flex-direction: column;
    }
    .prod-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.1); }
    .prod-card.featured { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
    .prod-thumb {
      aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;
      font-size: 3.5rem; position: relative; overflow: hidden;
    }
    .prod-thumb-badge {
      position: absolute; top: 14px; right: 14px;
      background: var(--accent); color: #fff;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; padding: 4px 10px; border-radius: 980px;
    }
    .prod-body { padding: 28px 24px; flex: 1; display: flex; flex-direction: column; }
    .prod-cat {
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; margin-bottom: 8px;
    }
    .prod-name { font-family: 'DM Serif Display', serif; font-size: 1.4rem; color: var(--dark); margin-bottom: 10px; line-height: 1.2; }
    .prod-desc { font-size: 0.88rem; color: var(--muted); line-height: 1.65; margin-bottom: 20px; flex: 1; }
    .prod-features { list-style: none; margin-bottom: 24px; display: flex; flex-direction: column; gap: 7px; }
    .prod-features li {
      font-size: 0.83rem; color: var(--mid); display: flex; align-items: flex-start; gap: 8px;
    }
    .prod-features li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; }
    .prod-footer {
      border-top: 1px solid var(--rule); padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .prod-price { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--dark); }
    .prod-price sub { font-family: 'DM Sans', sans-serif; font-size: 0.75rem; color: var(--muted); vertical-align: baseline; }

    @media(max-width:860px){ .products-grid { grid-template-columns: 1fr 1fr; } }
    @media(max-width:540px){ .products-grid { grid-template-columns: 1fr; } }

    /* COMPARISON TABLE */
    .compare-section {
      background: var(--bg3); padding: 100px 24px;
    }
    .compare-inner { max-width: 900px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 56px; }
    .compare-header .t-section { color: rgba(255,255,255,0.4); margin-bottom: 12px; }
    .compare-header .t-title   { color: #fff; }
    .compare-table {
      width: 100%; border-collapse: collapse; border-radius: var(--r-lg); overflow: hidden;
    }
    .compare-table thead th {
      padding: 20px 24px; text-align: left; font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255,255,255,0.4);
      background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .compare-table thead th.highlight { color: var(--accent); background: rgba(0,113,227,0.1); }
    .compare-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.06); }
    .compare-table tbody tr:last-child { border-bottom: none; }
    .compare-table tbody td {
      padding: 18px 24px; font-size: 0.9rem; color: rgba(255,255,255,0.7);
      background: rgba(255,255,255,0.02);
    }
    .compare-table tbody td.highlight { background: rgba(0,113,227,0.07); color: #fff; }
    .compare-table .check { color: var(--green); font-size: 1rem; }
    .compare-table .cross { color: rgba(255,255,255,0.2); font-size: 1rem; }

    /* FAQ */
    .faq-section { max-width: 720px; margin: 0 auto; padding: 100px 24px; }
    .faq-header { text-align: center; margin-bottom: 56px; }
    .faq-item {
      border-bottom: 1px solid var(--rule); overflow: hidden;
    }
    .faq-q {
      width: 100%; background: none; border: none; text-align: left; padding: 22px 0;
      font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 600; color: var(--dark);
      cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px;
    }
    .faq-q:hover { color: var(--accent); }
    .faq-icon { font-size: 1.2rem; color: var(--muted); flex-shrink: 0; transition: transform 0.2s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); color: var(--accent); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s; }
    .faq-item.open .faq-a { max-height: 200px; padding-bottom: 20px; }
    .faq-a p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; }

    /* ═══════════════════════════════════════
       MODAL — post-mortem fixes applied:
       - align-items: flex-start (scrollable)
       - overflow-y: auto on overlay
       - all listeners via addEventListener
       - try-catch on all storage
    ═══════════════════════════════════════ */
    .overlay {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,0.45); backdrop-filter: blur(12px);
      align-items: flex-start; justify-content: center;
      padding: 20px; overflow-y: auto;
    }
    .overlay.open { display: flex; animation: fadeIn 0.15s ease; }
    @keyframes fadeIn { from{opacity:0;}to{opacity:1;} }
    .modal {
      background: #fff; border-radius: var(--r-xl); padding: 48px 40px 40px;
      max-width: 480px; width: 100%; position: relative;
      margin: auto; animation: slideUp 0.18s ease;
      box-shadow: 0 24px 80px rgba(0,0,0,0.2);
    }
    @keyframes slideUp { from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);} }
    .modal-x {
      position: absolute; top: 18px; right: 18px;
      background: #f5f5f7; border: none; border-radius: 50%;
      width: 30px; height: 30px; font-size: 0.9rem; color: var(--muted);
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .modal-x:hover { background: #e8e8ed; }
    .modal-eyebrow {
      display: inline-block; font-size: 0.68rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent);
      margin-bottom: 12px;
    }
    .modal h2 { font-family: 'DM Serif Display', serif; font-size: 1.8rem; margin-bottom: 6px; color: var(--dark); }
    .modal-desc { font-size: 0.88rem; color: var(--muted); line-height: 1.6; margin-bottom: 28px; }
    .field { margin-bottom: 14px; }
    .field label {
      display: block; font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 7px;
    }
    .field input, .field select {
      width: 100%; padding: 12px 16px; border: 1.5px solid #d2d2d7;
      border-radius: var(--r-sm); font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem; color: var(--dark); background: #fff;
      outline: none; transition: border-color 0.15s;
    }
    .field input:focus, .field select:focus { border-color: var(--accent); }
    .field input::placeholder { color: #b0b0b8; }
    .field select option { color: var(--dark); }
    .modal-cta {
      width: 100%; margin-top: 6px; padding: 14px;
      background: var(--dark); color: #fff; border: none; border-radius: 980px;
      font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.95rem;
      cursor: pointer; transition: background 0.15s, transform 0.1s;
    }
    .modal-cta:hover { background: #3a3a3c; transform: scale(1.01); }
    .modal-note { text-align: center; font-size: 0.72rem; color: #b0b0b8; margin-top: 12px; }
    .success-view { display: none; text-align: center; padding: 16px 0; }
    .success-view.show { display: block; animation: fadeUp 0.3s ease; }
    .success-emoji { font-size: 3rem; margin-bottom: 16px; }
    .success-view h3 { font-family: 'DM Serif Display', serif; font-size: 1.8rem; margin-bottom: 8px; color: var(--dark); }
    .success-view p  { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    /* ═══════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════ */
    footer {
      background: #1d1d1f; padding: 48px 24px 36px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .footer-inner { max-width: 1000px; margin: 0 auto; }
    .footer-top {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px;
      padding-bottom: 36px; border-bottom: 1px solid rgba(255,255,255,0.1);
      margin-bottom: 28px;
    }
    .footer-brand .logo { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: #fff; display: block; margin-bottom: 10px; }
    .footer-brand .logo span { color: var(--accent); }
    .footer-brand p { font-size: 0.82rem; color: rgba(255,255,255,0.4); line-height: 1.65; }
    .footer-col h4 { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 14px; }
    .footer-col a  { display: block; font-size: 0.82rem; color: rgba(255,255,255,0.5); text-decoration: none; margin-bottom: 9px; cursor: pointer; transition: color 0.15s; }
    .footer-col a:hover { color: #fff; }
    .footer-bottom { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .footer-copy { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
    .footer-legal { display: flex; gap: 20px; }
    .footer-legal a { font-size: 0.75rem; color: rgba(255,255,255,0.3); text-decoration: none; cursor: pointer; }
    .footer-legal a:hover { color: rgba(255,255,255,0.7); }

    @media(max-width:700px){
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media(max-width:420px){
      .footer-top { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- ══════════════════════════════════════
       NAV
  ══════════════════════════════════════ -->
  <nav>
    <div class="nav-logo" id="navLogo">SUFYX<span>-AI</span></div>
    <div class="nav-links">
      <a id="navHome">Home</a>
      <a id="navProducts">Products</a>
      <a id="navBlog">Blog</a>
      <a id="navFeatures">Features</a>
      <a id="navContact">Contact</a>
    </div>
    <div class="nav-right">
      <button class="btn btn-text btn-sm" id="navLearnMore">Learn more</button>
      <a href="agent-dashboard.html" target="_blank" style="display:inline-flex;align-items:center;gap:6px;background:rgba(99,102,241,0.12);border:1px solid rgba(99,102,241,0.3);border-radius:8px;color:#A78BFA;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.78rem;padding:8px 14px;text-decoration:none;transition:all 0.15s;" onmouseover="this.style.background='rgba(99,102,241,0.22)'" onmouseout="this.style.background='rgba(99,102,241,0.12)'">🤖 Agent</a>
      <button class="btn btn-dark btn-sm nav-cta" id="navCta">Get started</button>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">
    <a id="mmHome">Home</a>
    <a id="mmProducts">Products</a>
    <a id="mmBlog">Blog</a>
    <a id="mmContact">Contact</a>
    <a href="agent-dashboard.html" target="_blank" style="color:#A78BFA;display:flex;align-items:center;gap:8px;">🤖 AI Agent Dashboard</a>
    <button class="btn btn-dark" id="mmCta">Get started</button>
  </div>

  <!-- ══════════════════════════════════════
       PAGE 1 — HOME
  ══════════════════════════════════════ -->
  <div class="page active" id="page1">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-eyebrow">New — AI Digital Products Suite 2026</div>
      <h1 class="t-hero">Intelligence,<br><em>delivered.</em></h1>
      <p class="hero-sub">SUFYX-AI sells premium AI-powered digital products that automate your workflows, generate content, and grow your business — all ready to deploy in minutes.</p>
      <div class="hero-actions">
        <button class="btn btn-primary" id="heroShop">Shop products</button>
        <button class="btn btn-ghost" id="heroLearn">See what's inside</button>
      </div>
      <div class="hero-social-proof">
        <div class="proof-avatars">
          <span>AK</span><span>SR</span><span>MJ</span><span>PD</span>
        </div>
        <p class="proof-text"><strong>1,200+</strong> businesses already using SUFYX-AI</p>
      </div>
    </section>

    <!-- PREVIEW -->
    <div class="preview-section">
      <div class="preview-inner">
        <div class="preview-text">
          <div class="t-section">Built for results</div>
          <h2 class="t-title" style="color:#fff;">Real AI products.<br>Real outcomes.</h2>
          <p class="t-body">Every product in the SUFYX-AI catalogue is production-ready, battle-tested, and built to generate measurable results from day one.</p>
          <button class="btn btn-white" id="previewCta">Explore the catalogue</button>
        </div>
        <div class="preview-mockup">
          <div>
            <div class="mock-bar">
              <div class="mock-dot" style="background:#ff5f57;"></div>
              <div class="mock-dot" style="background:#febc2e;"></div>
              <div class="mock-dot" style="background:#28c840;"></div>
            </div>
          </div>
          <div class="mock-grid">
            <div class="mock-card">
              <div class="mock-stat" style="color:#0071E3;">+340%</div>
              <div class="mock-line w80"></div>
              <div class="mock-line w60"></div>
            </div>
            <div class="mock-card">
              <div class="mock-stat" style="color:#34C759;">$12.4k</div>
              <div class="mock-line w80"></div>
              <div class="mock-line w40"></div>
            </div>
            <div class="mock-card">
              <div class="mock-line w60"></div>
              <div class="mock-line w80"></div>
              <div class="mock-line w40"></div>
            </div>
            <div class="mock-card">
              <div class="mock-stat" style="color:#FF9F0A;">48hrs</div>
              <div class="mock-line w80"></div>
              <div class="mock-line w60"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- FEATURES -->
    <section class="features-section" id="features">
      <div class="features-header">
        <div class="t-section">Why SUFYX-AI</div>
        <h2 class="t-title">Everything you need.<br>Nothing you don't.</h2>
      </div>
      <div class="feat-grid">
        <div class="feat-tile">
          <div class="feat-icon" style="background:#EFF6FF;">🤖</div>
          <div class="feat-name">Ready-to-Deploy AI</div>
          <div class="feat-desc">Every product ships fully configured. No technical setup required — buy, download, and use within minutes.</div>
        </div>
        <div class="feat-tile">
          <div class="feat-icon" style="background:#F0FDF4;">⚡</div>
          <div class="feat-name">Instant Automation</div>
          <div class="feat-desc">Pre-built workflows for Make, Zapier and n8n that connect your tools and eliminate manual work immediately.</div>
        </div>
        <div class="feat-tile">
          <div class="feat-icon" style="background:#FFF7ED;">📈</div>
          <div class="feat-name">Revenue-Focused</div>
          <div class="feat-desc">Every product is designed around a single metric: growing your revenue or saving your time. Often both.</div>
        </div>
        <div class="feat-tile">
          <div class="feat-icon" style="background:#FDF4FF;">🎨</div>
          <div class="feat-name">White-Label Ready</div>
          <div class="feat-desc">Resell our products under your own brand. Full white-label rights included with every bundle purchase.</div>
        </div>
        <div class="feat-tile">
          <div class="feat-icon" style="background:#FFF1F2;">🔒</div>
          <div class="feat-name">Lifetime Access</div>
          <div class="feat-desc">Pay once, own forever. All future updates to your purchased products are included at no extra charge.</div>
        </div>
        <div class="feat-tile">
          <div class="feat-icon" style="background:#F0F9FF;">💬</div>
          <div class="feat-name">Priority Support</div>
          <div class="feat-desc">Get help from our team via WhatsApp within 24 hours. We stay with you until your product is working perfectly.</div>
        </div>
      </div>
    </section>

    <!-- NUMBERS -->
    <div class="numbers-section">
      <div class="numbers-inner">
        <div class="num-cell">
          <div class="num-val">1.2<span>k+</span></div>
          <div class="num-lbl">Happy Customers</div>
        </div>
        <div class="num-cell">
          <div class="num-val">18<span>+</span></div>
          <div class="num-lbl">AI Products</div>
        </div>
        <div class="num-cell">
          <div class="num-val">4.9<span>★</span></div>
          <div class="num-lbl">Average Rating</div>
        </div>
        <div class="num-cell">
          <div class="num-val">48<span>h</span></div>
          <div class="num-lbl">Avg. Time to ROI</div>
        </div>
      </div>
    </div>

    <!-- TESTIMONIALS -->
    <section class="testimonials-section">
      <div class="testi-header">
        <div class="t-section" style="margin-bottom:12px;">Customer Stories</div>
        <h2 class="t-title">Trusted by builders<br>around the world.</h2>
      </div>
      <div class="testi-grid">
        <div class="testi-card">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">"The AI content bot alone saved us 12 hours a week. We deployed it in under an hour and it paid for itself on day two."</p>
          <div class="testi-author">
            <div class="testi-avatar" style="background:linear-gradient(135deg,#667eea,#764ba2);">AR</div>
            <div>
              <div class="testi-name">Arjun Rao</div>
              <div class="testi-role">Founder, GrowthStack</div>
            </div>
          </div>
        </div>
        <div class="testi-card">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">"Bought the WhatsApp automation bundle. My lead response time went from 6 hours to 30 seconds. Revenue is up 40% this quarter."</p>
          <div class="testi-author">
            <div class="testi-avatar" style="background:linear-gradient(135deg,#11998e,#38ef7d);">SM</div>
            <div>
              <div class="testi-name">Sana Mirza</div>
              <div class="testi-role">E-commerce Owner</div>
            </div>
          </div>
        </div>
        <div class="testi-card">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">"The quality of the Zapier workflow templates is insane. Professional-grade systems at a fraction of what an agency would charge."</p>
          <div class="testi-author">
            <div class="testi-avatar" style="background:linear-gradient(135deg,#f093fb,#f5576c);">PK</div>
            <div>
              <div class="testi-name">Priya Kapoor</div>
              <div class="testi-role">Marketing Consultant</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA BAND -->
    <div class="cta-band">
      <h2>Start automating today.</h2>
      <p>Browse our full catalogue of AI products and pick what fits your business.</p>
      <div class="cta-band-btns">
        <button class="btn btn-white" id="ctaBandShop">Browse products</button>
        <button class="btn btn-ghost" style="color:#fff;border-color:rgba(255,255,255,0.4);" id="ctaBandContact">Talk to us</button>
      </div>
    </div>

    <!-- FOOTER -->
    <footer>
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <span class="logo">SUFYX<span>-AI</span></span>
